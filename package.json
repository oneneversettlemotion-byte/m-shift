{
  "name": "m-shift",
  "version": "1.0.2",
  "description": "M-SHIFT — Professional Media Format Converter",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "start:dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac dmg zip"
  },
  "build": {
    "appId": "com.mshift.app",
    "productName": "M-SHIFT",
    "copyright": "Copyright © 2024 M-SHIFT",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64", "universal"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64", "universal"]
        }
      ],
      "darkModeSupport": true
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "zip",  "arch": ["x64"] }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/*/{test,__tests__,tests,spec,example,examples}/**",
      "!node_modules/**/*.{md,ts,map}",
      "!**/._*",
      "!**/{.DS_Store,.git,.svn,CVS,RCS,SCCS,.hg,.idea,.project}",
      "!**/.eslintrc.json",
      "!**/.npmignore",
      "!**/.editorconfig"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/@ffmpeg-installer/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "oneneversettlemotion-byte",
      "repo": "m-shift",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3"
  }
}
